# Reality Fork — environment config

# Which LLM provider to use: "minimax" (default), "gemini", or "ollama"
LLM_PROVIDER=minimax

# Override the default model for the chosen provider.
# MiniMax default: MiniMax-M2.7-highspeed
# Gemini default: gemini-2.5-flash-lite
# Ollama default: qwen3.5:397b
# LLM_MODEL=

# Override RPM cap for the rate limiter (defaults: minimax=60, gemini=5, ollama=60)
# LLM_RPM=

# --- MiniMax (default, Anthropic-compatible endpoint) ---
# Get a key: https://platform.minimax.io
MINIMAX_API_KEY= 
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# --- Gemini (alternate, free tier) ---
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# --- Ollama Cloud (alternate, free) ---
# NOTE: Ollama Cloud does not strictly enforce JSON schemas.
# OLLAMA_API_KEY=
# OLLAMA_HOST=https://ollama.com
