# Reality Fork — environment config

# Which LLM provider to use: "ollama" (default) or "gemini"
LLM_PROVIDER=ollama

# Override the default model for the chosen provider.
# Ollama Cloud defaults: qwen3-coder:480b-cloud
# Gemini defaults: gemini-2.0-flash
# LLM_MODEL=qwen3-coder:480b-cloud

# --- Ollama Cloud (free) ---
# Get a key: https://ollama.com/settings/keys
OLLAMA_API_KEY=
# OLLAMA_HOST=https://ollama.com

# --- Gemini (alternate) ---
# GEMINI_API_KEY=
