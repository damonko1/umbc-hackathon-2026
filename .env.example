# Reality Fork — environment config

# Which LLM provider to use: "gemini" (default, has real schema enforcement) or "ollama"
LLM_PROVIDER=gemini

# Override the default model for the chosen provider.
# Gemini default: gemini-2.0-flash
# Ollama default: qwen3.5:397b
# LLM_MODEL=gemini-2.0-flash

# --- Gemini (default, free tier) ---
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Ollama Cloud (alternate, free) ---
# NOTE: Ollama Cloud does not strictly enforce JSON schemas — outputs may need
# prompt-level coaxing. Use Gemini for reliable structured output.
# OLLAMA_API_KEY=
# OLLAMA_HOST=https://ollama.com
