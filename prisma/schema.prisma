generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionRunStatus {
  pending
  completed
  failed
}

enum MemoryItemKind {
  decision_summary
}

enum MemoryItemStatus {
  active
  archived
}

model Device {
  id           String        @id @default(uuid()) @db.Uuid
  deviceToken  String        @unique @map("device_token")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  decisionRuns DecisionRun[]
  memoryItems   MemoryItem[]

  @@map("devices")
}

model DecisionRun {
  id            String              @id @default(uuid()) @db.Uuid
  deviceId      String              @map("device_id") @db.Uuid
  title         String
  question      String
  context       String?
  goals         String?
  speed         String
  timeUnit      String              @map("time_unit")
  numSteps      Int                 @map("num_steps")
  planRationale String              @map("plan_rationale")
  status        DecisionRunStatus
  errorMessage  String?             @map("error_message")
  chosenForkId  String?             @map("chosen_fork_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  device        Device              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  options       DecisionOption[]
  payload       DecisionRunPayload?
  memoryItem    MemoryItem?

  @@index([deviceId, createdAt(sort: Desc)])
  @@map("decision_runs")
}

model DecisionOption {
  id            String      @id @default(uuid()) @db.Uuid
  decisionRunId String      @map("decision_run_id") @db.Uuid
  forkId        String      @map("fork_id")
  label         String
  description   String?
  summary       String?
  sortOrder     Int         @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  decisionRun   DecisionRun @relation(fields: [decisionRunId], references: [id], onDelete: Cascade)

  @@unique([decisionRunId, forkId])
  @@index([decisionRunId, sortOrder])
  @@map("decision_options")
}

model DecisionRunPayload {
  decisionRunId String      @id @map("decision_run_id") @db.Uuid
  inputJson     Json        @map("input_json")
  planJson      Json        @map("plan_json")
  timelinesJson Json        @map("timelines_json")
  resultJson    Json        @map("result_json")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  decisionRun   DecisionRun @relation(fields: [decisionRunId], references: [id], onDelete: Cascade)

  @@map("decision_run_payloads")
}

model MemoryItem {
  id                String           @id @default(uuid()) @db.Uuid
  deviceId          String           @map("device_id") @db.Uuid
  decisionRunId     String?          @unique @map("decision_run_id") @db.Uuid
  kind              MemoryItemKind
  title             String
  summary           String
  question          String
  chosenForkId      String?          @map("chosen_fork_id")
  chosenForkLabel   String?          @map("chosen_fork_label")
  status            MemoryItemStatus @default(active)
  pinned            Boolean          @default(false)
  userEditedTitle   Boolean          @default(false) @map("user_edited_title")
  userEditedSummary Boolean          @default(false) @map("user_edited_summary")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  device            Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  decisionRun       DecisionRun?     @relation(fields: [decisionRunId], references: [id], onDelete: SetNull)

  @@index([deviceId, status, pinned, updatedAt(sort: Desc)])
  @@map("memory_items")
}
